// Prisma schema for MongoDB
// Set DATABASE_URL in .env, e.g.:
//   mongodb+srv://user:password@cluster.mongodb.net/mydb
//   mongodb://localhost:27017/mydb

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum ExchangeType {
  binance
  bybit
  okx
  backpack
  kraken
  hyperliquid
  aster
}

model Exchange {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  name           String?      // display name; when null, use type (e.g. for existing records)
  apiKey         String
  secretKey      String
  passphrase     String?
  walletAddress  String?      // required for some DEXs (e.g. Hyperliquid: EVM wallet address)
  type           ExchangeType
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  tradeBots      TradeBot[]
}

enum TradeBotDirection {
  LONG
  SHORT
  BOTH
}

model TradeBot {
  id         String            @id @default(auto()) @map("_id") @db.ObjectId
  exchangeId String            @db.ObjectId
  exchange   Exchange          @relation(fields: [exchangeId], references: [id])
  strategy   String            // webhook strategy name, e.g. DIY, Momentum
  direction  TradeBotDirection
  ticker     String
  amount     String            // USD amount allowed to trade
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  positions  Position[]
}

enum PositionStatus {
  OPEN
  CLOSED
}

model Position {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  botId             String         @db.ObjectId
  bot               TradeBot      @relation(fields: [botId], references: [id])
  signalId          String?        @db.ObjectId
  exchangeId        String         @db.ObjectId
  symbol            String
  side              String         // LONG or SHORT
  quantity          String
  entryPrice        String
  status            PositionStatus @default(OPEN)
  externalOrderId   String?
  tpOrderId         String?
  slOrderId         String?
  closedAt          DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model Signal {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  strategy           String
  symbol             String
  direction          String?  // LONG or SHORT, from payload or derived from MA/momentum
  slROI              String
  tpROI              String
  longMALine         String?
  crossMASignalDown  String?
  crossMASignalUp    String?
  momentumLine       String?
  MALine             String?
  positionSize       String
  leverage           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Webhook {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  payload   String   // full incoming webhook body as JSON string
  symbol    String?  // extracted for filtering (ticker)
  strategy  String?  // extracted for filtering
  direction String?  // extracted for filtering (e.g. LONG, SHORT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
