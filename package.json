{
  "name": "lifechange-ludik",
  "version": "0.0.1",
  "private": true,
  "description": "Lifechange Ludik monorepo",
  "scripts": {
    "build": "pnpm -r run build",
    "build:api": "pnpm --filter api run build",
    "build:exchange": "pnpm --filter exchange run build",
    "dev": "pnpm --filter api run start:dev",
    "dev:hyperliquid": "EXCHANGE_CODE=hyperliquid pnpm --filter exchange run start:dev",
    "dev:backpack": "EXCHANGE_CODE=backpack pnpm --filter exchange run start:dev",
    "dev:web": "pnpm --filter web run dev",
    "start:api": "pnpm --filter api run start",
    "start:api:prod": "pnpm --filter api run start:prod",
    "start:exchange": "pnpm --filter exchange run start",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm --filter api run test:e2e",
    "format": "prettier --write \"**/*.{ts,js,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2"
  },
  "dependencies": {
    "ccxt": "^4.5.40"
  },
  "packageManager": "pnpm@9.9.0+sha512.60c18acd138bff695d339be6ad13f7e936eea6745660d4cc4a776d5247c540d0edee1a563695c183a66eb917ef88f2b4feb1fc25f32a7adcadc7aaf3438e99c1"
}
